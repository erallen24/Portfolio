---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Engine & Systems Programmer">
  <header class="mb-8 border-b border-slate-800 pb-4">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight uppercase">Evan Allen</h1>
    <p class="text-cyan-400 mt-2 text-lg">// Engine & Systems Programmer</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    
    <div class="col-span-1 md:col-span-2 bg-slate-900 border border-slate-800 p-6 rounded">
      <div class="flex items-center gap-2 mb-4 border-b border-slate-800 pb-2">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
        <span class="ml-2 text-xs text-slate-500">sys_overview.sh</span>
      </div>
      <p class="leading-relaxed text-sm md:text-base">
        Specializing in robust systems architecture, low-level graphics APIs, and high-performance gameplay mechanics. Bridging the gap between complex engineering and fluid player experience.
      </p>
    </div>

    <div class="bg-slate-900 border border-slate-800 p-6 rounded">
      <h2 class="text-lg text-slate-100 mb-4 uppercase tracking-wider">// Capabilities</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex justify-between border-b border-slate-800/50 pb-1"><span>C++ / Python</span> <span class="text-emerald-400">[ACTIVE]</span></li>
        <li class="flex justify-between border-b border-slate-800/50 pb-1"><span>Unreal Engine 5</span> <span class="text-emerald-400">[ACTIVE]</span></li>
        <li class="flex justify-between border-b border-slate-800/50 pb-1"><span>Vulkan / GLSL</span> <span class="text-emerald-400">[ACTIVE]</span></li>
      </ul>
    </div>

    <a href="/fcf" class="bg-slate-900 border border-slate-800 p-6 rounded hover:border-cyan-500 hover:bg-slate-800/50 transition-all cursor-pointer group block text-left">
      <div class="flex justify-between items-start mb-2">
        <h3 class="text-lg font-bold text-slate-100 group-hover:text-cyan-400 transition-colors">Fluidity Character Framework</h3>
        <span class="text-xs text-slate-500 border border-slate-700 px-2 py-1 rounded">UE5</span>
      </div>
      <p class="text-sm text-slate-400">Advanced locomotion system leveraging the Mover plugin. Custom C++ character states and animation logic.</p>
    </a>

    <a href="/add-venture" class="bg-slate-900 border border-slate-800 p-6 rounded hover:border-cyan-500 hover:bg-slate-800/50 transition-all cursor-pointer group block text-left">
      <div class="flex justify-between items-start mb-2">
        <h3 class="text-lg font-bold text-slate-100 group-hover:text-cyan-400 transition-colors">Add-Venture</h3>
        <span class="text-xs text-slate-500 border border-slate-700 px-2 py-1 rounded">C++ / 2.5D</span>
      </div>
      <p class="text-sm text-slate-400">Action-exploration title featuring highly optimized custom collision math and streamlined game loops.</p>
    </a>

  </div>
</Layout>